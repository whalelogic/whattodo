package views

templ About() {
    @Layout("About") {
        <div class="max-w-2xl mx-auto py-12 px-4">
            <h1 class="text-3xl font-bold text-slate-800 mb-2">About This App</h1>
            <p class="text-slate-500 mb-8">This app is a simple AI-powered chatbot that can answer questions about things to do in Connecticut. It uses OpenAI's GPT-4 model to generate responses based on the user's input.</p>

            <h2 class="text-2xl font-bold text-slate-800 mb-2">How It Works</h2>
            <p class="text-slate-500 mb-8">When you ask a question, the app sends your input to the GPT-4 model, which processes the information and generates a relevant response. The response is then displayed in the chat window for you to read.</p>
            <h2 class="text-2xl font-bold text-slate-800 mb-2">Privacy</h2>
            <p class="text-slate-500 mb-8">We take your privacy seriously. Your questions and the generated responses are not stored or shared with any third parties. The app only uses your input to generate a response in real-time.</p>
            <h2 class="text-2xl font-bold text-slate-800 mb-2">Feedback</h2>
            <p class="text-slate-500 mb-8">We welcome your feedback! If you have any suggestions or encounter any issues, please reach out to us through the contact form on our website. Your input helps us improve the app and provide a better experience for all users.</p>
        </div>
    }
}
